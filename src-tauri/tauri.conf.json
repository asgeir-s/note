{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Dump",
  "version": "0.1.0",
  "identifier": "com.dump.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Dump",
        "width": 800,
        "height": 700,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "qmd",
          "cmd": "qmd",
          "args": true
        }
      ]
    }
  }
}
